{
  "expo": {
    "name": "VidSlice",
    "slug": "vidslice",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vidslice.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "VidSlice needs access to save your split videos.",
        "NSPhotoLibraryAddUsageDescription": "VidSlice needs access to save your split videos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "package": "com.vidslice.app",
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_VIDEO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-av",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow VidSlice to access your photos.",
          "savePhotosPermission": "Allow VidSlice to save split videos.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "ffmpeg-kit-react-native",
        {
          "package": "min"
        }
      ]
    ],
    "scheme": "vidslice",
    "experiments": {
      "typedRoutes": true
    }
  }
}
